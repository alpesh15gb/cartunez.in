# ==========================================
# Cartunez Medusa - Environment Variables
# ==========================================

# App
NODE_ENV=development
PORT=9000

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/cartunez_medusa
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=medusa
DB_PASSWORD=supersecret
DB_DATABASE=cartunez_medusa

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT & Auth
JWT_SECRET=super-secret-jwt-token-change-in-production
COOKIE_SECRET=super-secret-cookie-change-in-production
ADMIN_CORS=http://localhost:7001,http://localhost:8000

# Meilisearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=your-master-key-here

# File Storage (Local or S3)
FILE_STORAGE=local
S3_BUCKET=cartunez-uploads
S3_REGION=ap-south-1
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key

# Stripe (if using)
STRIPE_API_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Razorpay (if using)
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret

# Mail (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Admin
ADMIN_EMAIL=admin@cartunez.in

# ApexBooks ERP integration
APEXBOOKS_ENABLED=false
APEXBOOKS_BASE_URL=https://api.apexbooks.example
APEXBOOKS_API_KEY=
APEXBOOKS_WEBHOOK_SECRET=
APEXBOOKS_TIMEOUT_MS=10000
APEXBOOKS_MAX_RETRIES=3
