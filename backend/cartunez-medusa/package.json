{
  "name": "cartunez-medusa",
  "version": "1.0.0",
  "description": "Cartunez - Automotive E-Commerce Platform powered by MedusaJS",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node --transpile-only src/index.ts",
    "seed": "node seed-data.js",
    "scrape": "node scripts/scrape-neowheels.js",
    "import:wheels": "node scripts/import-neowheels.js",
    "import:neodrift": "node scripts/import-neodrift.js",
    "import:sahibacar": "node scripts/import-sahibacar.js",
    "fix:images": "node scripts/fix-product-images.js",
    "link:images": "node scripts/link-images.js",
    "map:finish-images": "node scripts/map-finish-images.js",
    "validate:images": "node scripts/validate-product-images.js",
    "verify:migration": "node scripts/verify-migration.js",
    "migration:run": "ts-node --transpile-only node_modules/typeorm/cli.js migration:run -d src/utils/datasource.ts",
    "migration:generate": "ts-node --transpile-only node_modules/typeorm/cli.js migration:generate -d src/utils/datasource.ts",
    "lint": "eslint --ext .ts src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@medusajs/admin": "^7.1.18",
    "ajv": "^8.12.0",
    "@medusajs/cache-redis": "1.8.9",
    "@medusajs/event-bus-redis": "1.8.9",
    "@medusajs/file-local": "^1.0.4",
    "@medusajs/medusa": "1.20.4",
    "@medusajs/medusa-cli": "^1.3.22",
    "@medusajs/utils": "^1.11.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "ioredis": "^5.3.2",
    "medusa-fulfillment-manual": "^1.1.9",
    "medusa-interfaces": "^1.3.7",
    "medusa-extender": "^1.8.4",
    "medusa-payment-manual": "^1.0.9",
    "medusa-plugin-meilisearch": "1.0.4",
    "meilisearch": "^0.41.0",
    "pg": "^8.12.0",
    "typeorm": "^0.3.20",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7",
    "eslint": "^8.56.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "webpack": "5.84.1",
    "webpackbar": "5.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "medusa",
    "ecommerce",
    "automotive",
    "cartunez"
  ],
  "license": "MIT"
}
