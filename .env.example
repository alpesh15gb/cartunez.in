# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=cartunez
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_postgres_password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_password

# Meilisearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_API_KEY=CHANGE_ME_meilisearch_api_key
MEILI_MASTER_KEY=CHANGE_ME_meilisearch_api_key
NEXT_PUBLIC_MEILISEARCH_HOST=http://localhost:7700

# Medusa
JWT_SECRET=CHANGE_ME_jwt_secret_min_32_chars
COOKIE_SECRET=CHANGE_ME_cookie_secret_min_32_chars
ADMIN_CORS=http://localhost:7001,http://localhost:3000,http://localhost:9000,https://cartunez.in,https://shop.cartunez.in
STORE_CORS=http://localhost:3001,http://localhost:3000,http://localhost:5173,https://cartunez.in,https://shop.cartunez.in
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_CHANGE_ME

# FastAPI
NEXT_PUBLIC_API_URL=https://api.cartunez.in
API_ADMIN_KEY=CHANGE_ME_random_32_char_string
JWT_SECRET_KEY=CHANGE_ME_jwt_secret_key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Razorpay
RAZORPAY_KEY_ID=rzp_CHANGE_ME
RAZORPAY_KEY_SECRET=CHANGE_ME_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=whsec_CHANGE_ME
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_CHANGE_ME

# S3 Storage
S3_BUCKET=cartunez-assets
S3_REGION=ap-south-1
S3_ACCESS_KEY=CHANGE_ME_s3_access_key
S3_SECRET_KEY=CHANGE_ME_s3_secret_key
S3_ENDPOINT=https://s3.ap-south-1.amazonaws.com

# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Search Console
GOOGLE_SITE_VERIFICATION=xxxxxxxxxxxxxxxxxxxx

# Microsoft Clarity
NEXT_PUBLIC_CLARITY_ID=xxxxxxxxxx

# Facebook Pixel
NEXT_PUBLIC_FB_PIXEL_ID=123456789012345

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@cartunez.in
SMTP_PASSWORD=CHANGE_ME_smtp_password

# App URLs
NEXT_PUBLIC_BASE_URL=https://cartunez.in
NEXT_PUBLIC_STORE_URL=https://shop.cartunez.in
NEXT_PUBLIC_API_BASE_URL=https://api.cartunez.in
